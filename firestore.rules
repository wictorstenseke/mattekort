rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Option B: hardcoded superuser UID — only this account can create profiles with any role
    function isSuperuser() {
      return request.auth != null && request.auth.uid == 'jyIi04e9LqMF9xMet0HCHX46dsF2';
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/profiles/$(userId)).data.spaceId == request.auth.uid;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/profiles/$(userId)).data.spaceId == request.auth.uid;
    }

    match /profiles/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null && resource.data.spaceId == request.auth.uid;
      // Admins create user profiles in their space — role is locked to 'user'
      allow create: if request.auth != null
        && request.resource.data.spaceId == request.auth.uid
        && request.resource.data.role == 'user';
      // Only hardcoded superuser can create profiles with any role
      allow create: if isSuperuser();
      // Option A: users can update their own profile but cannot change role or spaceId
      allow update: if request.auth != null
        && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'spaceId']);
    }

    match /spaces/{spaceId} {
      allow read, write: if request.auth != null && request.auth.uid == spaceId;
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
