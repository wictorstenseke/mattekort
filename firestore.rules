rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/profiles/$(userId)).data.spaceId == request.auth.uid;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/profiles/$(userId)).data.spaceId == request.auth.uid;
    }

    match /profiles/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null && resource.data.spaceId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.spaceId == request.auth.uid
        && request.resource.data.role == 'user';
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'superuser';
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /spaces/{spaceId} {
      allow read, write: if request.auth != null && request.auth.uid == spaceId;
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
